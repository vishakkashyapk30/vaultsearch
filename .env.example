# Copy to .env — docker compose reads it automatically. Never commit .env.

# --- LLM (local, no key needed) ---
OLLAMA_MODEL=gemma3:4b
USE_RERANKER=true

# --- Agent layer ---
# Max evidence-refinement rounds after the initial retrieval plan.
AGENT_MAX_ROUNDS=2
# Advisory groundedness critic on each answer (adds one LLM call).
USE_CRITIC=true

# --- LocalStack (optional cloud-native layer) ---
# REQUIRED to start LocalStack (2026+ images need a token even on the free
# tier). Get yours at https://app.localstack.cloud → Auth Tokens.
#LOCALSTACK_AUTH_TOKEN=your-token-here

# Point boto3 at LocalStack (cloud/ scripts default to this on their own).
#AWS_ENDPOINT_URL=http://localhost:4566

# Mirror audit events to DynamoDB (table created by cloud/main.tf).
#AUDIT_DYNAMODB_TABLE=vaultsearch-audit
